{% extends "layout/base.html.twig" %}

{% block title %}{{ title }} - Phlag Admin{% endblock %}

{% block content %}
<div class="environment-view">
    <div class="page-header">
        <h1>{{ title }}</h1>
        <div class="page-actions">
            <a href="{{ base_url }}/environments/{{ environment_id }}/edit" class="btn btn-primary">Edit</a>
            <button onclick="EnvironmentManager.delete({{ environment_id }})" class="btn btn-danger">Delete</button>
        </div>
    </div>

    <div id="loading" class="text-center" style="padding: 3rem;">
        <p>Loading environment...</p>
    </div>

    <div id="environment-details" class="hidden">
        <div class="card">
            <h2>Environment Information</h2>
            
            <div class="detail-grid">
                <div class="detail-item">
                    <label>Name:</label>
                    <span id="detail-name"></span>
                </div>

                <div class="detail-item">
                    <label>Created:</label>
                    <span id="detail-created"></span>
                </div>

                <div class="detail-item">
                    <label>Last Updated:</label>
                    <span id="detail-updated"></span>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <a href="{{ base_url }}/environments" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script src="{{ base_url }}/assets/js/environment.js"></script>
<script>
    // Load environment details when page loads
    document.addEventListener('DOMContentLoaded', function() {
        EnvironmentManager.init('{{ api_url }}');
        EnvironmentManager.loadSingle({{ environment_id }});
    });
</script>
{% endblock %}
